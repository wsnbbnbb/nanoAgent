# CodeAgent Environment Configuration

# LLM Configuration
OPENAI_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY = "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"
# LLM_BASE_URL = "https://integrate.api.nvidia.com/v1"
# OPENAI_MODEL = "moonshotai/kimi-k2.5"
# Agent Configuration
MEMORY_FILE=agent_memory.md
RULES_DIR=.agent/rules
SKILLS_DIR=.agent/skills
MCP_CONFIG=.agent/mcp.json

# Context Configuration
MAX_HISTORY_LENGTH=100
MAX_ITERATIONS=100
CONTEXT_WINDOW=128000
COMPRESSION_THRESHOLD=0.8

# Tool Output Configuration
TOOL_OUTPUT_MAX_LINES=2000
TOOL_OUTPUT_MAX_BYTES=51200
TOOL_OUTPUT_DIR=tool-output
TOOL_OUTPUT_RETENTION_DAYS=7

# Debug
DEBUG=false
LOG_LEVEL=INFO
SHOW_REACT_STEPS=true
SHOW_PROGRESS=true
